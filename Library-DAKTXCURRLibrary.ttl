  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><h2>Related Artifacts</h2><table class=\"grid\"><tr><td>depends-on</td><td><code>http://hl7.org/fhir/Library/FHIR-ModelInfo|4.0.1</code></td></tr><tr><td>depends-on</td><td><code>http://hl7.org/fhir/Library/FHIRHelpers|4.0.1</code></td></tr><tr><td>depends-on</td><td><code>https://path-global-health.github.io/MERindicators/Library/FHIRCommon|4.0.1</code></td></tr><tr><td>depends-on</td><td><a href=\"Library-DAKConcepts.html\">DAKConcepts</a></td></tr><tr><td>depends-on</td><td><a href=\"Library-DAKDataElements.html\">DAKDataElements</a></td></tr><tr><td>depends-on</td><td><a href=\"Library-DAKStratifiers.html\">DAKStratifiers</a></td></tr></table><h2>Parameters</h2><table class=\"grid\"><tr><td>Patient</td><td>out</td><td>0</td><td>1</td><td>Patient</td></tr><tr><td>Initial Population</td><td>out</td><td>0</td><td>1</td><td>boolean</td></tr><tr><td>Stratification</td><td>out</td><td>0</td><td>1</td><td>string</td></tr><tr><td>Dispense Stratification</td><td>out</td><td>0</td><td>1</td><td>string</td></tr></table><h2>Contents</h2><p><code>text/cql</code></p><pre><code class=\"language-sql\">// TX_CURR, WHO HIV.IND.AV.1\r\n// numerator only\r\n// Number of adults and children currently receiving antiretroviral therapy (ART)\r\n// Sum of age/sex disaggregates\r\n\r\n\r\nlibrary DAKTXCURR version '0.1.0'\r\n\r\nusing FHIR version '4.0.1'\r\n\r\ninclude FHIRHelpers version '4.0.1'\r\ninclude FHIRCommon version '4.0.1' called FC\r\n\r\ninclude DAKConcepts called Cx\r\ninclude DAKDataElements called PatientData\r\ninclude DAKStratifiers called DAKStratifiers\r\n\r\ncontext Patient\r\n\r\ndefine &quot;Initial Population&quot;: \r\n  PatientData.&quot;On ART&quot; and not PatientData.&quot;Deceased&quot;\r\n\r\n/* For continuous variable\r\n\r\ndefine &quot;Initial Population&quot;: \r\n  PatientData.&quot;On ART&quot;\r\n\r\ndefine &quot;Measure Population&quot;:\r\n  PatientData.&quot;On ART&quot;\r\n\r\ndefine &quot;Measure Population Exclusion&quot;:\r\n  PatientData.&quot;Deceased&quot;\r\n\r\ndefine &quot;Measure Observation&quot;:\r\n  PatientData.&quot;On ART&quot;\r\n*/\r\n\r\n/* for proportion\r\ndefine &quot;Initial Population&quot;: \r\n  PatientData.&quot;PLHIV&quot;\r\n\r\ndefine &quot;Denominator&quot;:\r\n  PatientData.&quot;PLHIV&quot;\r\n\r\ndefine &quot;Denominator-Exclusion&quot;:\r\n  PatientData.&quot;Deceased&quot;\r\n\r\ndefine &quot;Numerator-Exclusion&quot;: \r\n  PatientData.&quot;Deceased&quot;\r\n\r\n\r\n// todo: this is not showing up as true\r\n\r\ndefine &quot;Numerator&quot;:\r\n  PatientData.&quot;On ART&quot;\r\n*/\r\n\r\ndefine &quot;Stratification&quot;: \r\n  DAKStratifiers.&quot;Age Group/Sex/Location TXCURR&quot;\r\n\r\ndefine &quot;Dispense Stratification&quot;:\r\n  DAKStratifiers.&quot;Dispensing Quantity/Coarse Age/Sex/Location&quot;\r\n\r\n// define &quot;Initial population&quot;:\r\n//     exists &quot;Anti Retroviral Therapy Adults And Children&quot;\r\n  \r\n// define &quot;Anti Retroviral Therapy Adults And Children&quot;:\r\n//     ( [Observation: &quot;Anti Retroviral Therapy&quot;] ) o\r\n//         where o.value.coding[1]= &quot;Coded Answer&quot;\r\n//         or o.value.coding[2]= &quot;Coded Answer&quot;\r\n//         and o.status in {'final', 'amended', 'corrected'}\r\n//         and o.effective in day of &quot;Measurement Period&quot;\r\n</code></pre><p><code>Content not shown - (</code><code>application/elm+xml</code>, size = 2Kb)</p><p><code>Content not shown - (</code><code>application/elm+json</code>, size = 4Kb)</p></div>"
  ] ; # 
